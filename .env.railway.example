# Railway pilot deployment for ~15 users
NODE_ENV=production
SPORT=nba

# App URLs
# During the pilot, set APP_URL and NEXTAUTH_URL to the Railway public domain.
# Example: https://my-app.up.railway.app
APP_URL=
NEXTAUTH_URL=
NEXT_PUBLIC_APP_URL=

# Internal calls. If you do not have a private internal URL, reuse APP_URL.
INTERNAL_APP_URL=

# Auth
NEXTAUTH_SECRET=

# Database
# Short pilot can still run on SQLite if the file is mounted on a persistent volume.
# Before commercial launch, migrate to PostgreSQL.
# Optional override for runtime selection: sqlite | postgres
PRISMA_PROVIDER=
DATABASE_URL=
POSTGRES_DATABASE_URL=

# Billing
BILLING_PROVIDER=mercadopago
NEXT_PUBLIC_BILLING_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
# Obrigatorio para validar a assinatura dos webhooks do Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
# Optional override. Leave empty to use APP_URL + /api/webhooks/billing
MERCADOPAGO_WEBHOOK_URL=
NBA_MONTHLY_TESTER_PROMO_EMAILS=
NBA_MONTHLY_TESTER_PROMO_PRICE=10

# NBA data
NBA_DATA_PROVIDER=api-basketball
API_BASKETBALL_KEY=
BETSAPI_TOKEN=
BETSAPI_NBA_SPORT_ID=18
BETSAPI_NBA_LEAGUE_ID=10041830

# Optional bot / alerts
ENABLE_GAME_ALERTS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
